{
  "name": "@neuraiproject/neurai-sign-transaction",
  "description": "Signs a Neurai transaction",
  "version": "1.1.3",
  "source": "index.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build:cjs": "esbuild index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "build:esm": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs",
    "build:types": "tsc index.ts --declaration --emitDeclarationOnly --outDir dist --skipLibCheck --module esnext --moduleResolution node --target es2020",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && npm run build:types",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neuraiproject/neurai-sign-transaction.git"
  },
  "keywords": [
    "neurai"
  ],
  "author": "Neurai Team <",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/neuraiproject/neurai-sign-transaction/issues"
  },
  "homepage": "https://github.com/neuraiproject/neurai-sign-transaction#readme",
  "dependencies": {
    "@bitcoinerlab/secp256k1": "1.2.0",
    "@noble/post-quantum": "^0.6.0",
    "bitcoinjs-lib": "6.1.7",
    "ecpair": "3.0.0"
  },
  "devDependencies": {
    "@parcel/packager-ts": "^2.15.1",
    "@parcel/transformer-typescript-types": "^2.15.1",
    "@types/node": "^20.17.30",
    "esbuild": "^0.25.12",
    "jest": "^29.7.0",
    "parcel": "^2.15.1",
    "typescript": "5.8.3"
  }
}
